{
    "tasks": {
        "startup": [
            {
                "id": "rosbridge",
                "description": "ROS1 rosbridge_websocket",
                "command": "roslaunch",
                "args": [
                    "rosbridge_server",
                    "rosbridge_websocket.launch"
                ],
                "delay": 0
            }
        ],
        "mapping": [
            {
                "id": "gmapping",
                "description": "ROS1 GMapping 建图",
                "command": "roslaunch",
                "args": [
                    "slam_gmapping",
                    "slam_gmapping.launch"
                ],
                "delay": 0
            }
        ],
        "navigation": [
            {
                "id": "move_base",
                "description": "ROS1 导航栈 (AMCL + move_base)",
                "command": "roslaunch",
                "args": [
                    "fishbot_navigation",
                    "navigation.launch"
                ],
                "delay": 0
            }
        ]
    },
    "save_map": {
        "command": "rosrun",
        "args": [
            "map_server",
            "map_saver",
            "-f"
        ],
        "description": "保存地图（-f 后追加地图名和路径）",
        "save_dir": "/home/jiang/workspace/fishbot/maps"
    },
    "maps_dir": "/home/jiang/workspace/fishbot/maps",
    "topics": {
        "cmd_vel": "/cmd_vel",
        "battery": "/battery",
        "map": "/map",
        "scan": "/scan",
        "tf": "/tf",
        "odom": "/odom",
        "plan": "/move_base/NavfnROS/plan",
        "goal_pose": "/move_base_simple/goal",
        "initial_pose": "/initialpose",
        "navigate_feedback": "/move_base/feedback",
        "imu": "/imu"
    }
}
