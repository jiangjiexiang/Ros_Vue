{
    "tasks": {
        "startup": [
            {
                "id": "foxglove",
                "description": "Foxglove 数据桥接 (高带宽模式)",
                "command": "ros2",
                "args": [
                    "run",
                    "foxglove_bridge",
                    "foxglove_bridge",
                    "--ros-args",
                    "-p",
                    "include_hidden:=true",
                    "-p",
                    "send_buffer_limit:=100000000",
                    "-p",
                    "num_threads:=4",
                    "-p",
                    "max_qos_depth:=10",
                    "-p",
                    "min_qos_depth:=10"
                ],
                "delay": 0
            }
        ],
        "mapping": [
            {
                "id": "mapCartographer",
                "description": "Cartographer 建图算法",
                "command": "ros2",
                "args": [
                    "launch",
                    "fishbot_cartographer",
                    "cartographer.launch.py"
                ],
                "delay": 0
            }
        ],
        "navigation": [
            {
                "id": "nav2",
                "description": "Nav2 导航栈 (AMCL + 路径规划)",
                "command": "ros2",
                "args": [
                    "launch",
                    "fishbot_navigation2",
                    "navigation2.launch.py"
                ],
                "delay": 0
            }
        ]
    },
    "save_map": {
        "command": "ros2",
        "args": [
            "run",
            "nav2_map_server",
            "map_saver_cli",
            "-f"
        ],
        "description": "保存地图（-f 后追加地图名和路径）",
        "save_dir": "/home/jiang/workspace/fishbot/maps"
    },
    "maps_dir": "/home/jiang/workspace/fishbot/maps",
    "paths": {
        "ros_setup": "/opt/ros/humble/setup.bash",
        "fishbot_workspace": "/home/jiang/workspace/fishbot",
        "extra_workspaces": [
            "/home/jiang/workspace/ros2_humble_mid360_simulation"
        ]
    },
    "ports": {
        "backend": 3000,
        "frontend": 5173
    },
    "node": {
        "nvm_version": "v0.39.7",
        "version": "lts/*"
    },
    "cleanup": {
        "startup_regex": "gzserver|gzclient|gazebo|rviz2|ros2|cartographer|foxglove|component_container_isolated|robot_state_publisher|nav2",
        "shutdown_regex": "ros2|cartographer|foxglove|component_container_isolated|robot_state_publisher|nav2"
    },
    "env": {
        "qt_x11_no_mitshm": "1",
        "libgl_always_software": "0",
        "gazebo_plugin_path_append": "/opt/ros/humble/lib"
    },
    "topics": {
        "cmd_vel": "/cmd_vel",
        "battery": "/battery",
        "map": "/map",
        "scan": "/scan",
        "tf": "/tf",
        "odom": "/odom",
        "plan": "/plan",
        "goal_pose": "/goal_pose",
        "initial_pose": "/initialpose",
        "navigate_feedback": "/navigate_to_pose/_action/feedback",
        "imu": "/imu",
        "lidar": "/livox/lidar"
    }
}
